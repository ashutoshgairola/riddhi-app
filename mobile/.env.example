EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Dev-only credentials used by SessionProvider to bootstrap a session when
# USE_BACKEND=true (src/api/index.ts) and no token is cached yet. Ignored in
# mock mode (USE_BACKEND=false, the default).
EXPO_PUBLIC_DEV_EMAIL=riddhi@example.com
EXPO_PUBLIC_DEV_PASSWORD=password123
