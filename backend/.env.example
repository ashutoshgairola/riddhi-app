DATABASE_URL=postgresql://riddhi:riddhi@localhost:5432/riddhi
JWT_SECRET=dev_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ANTHROPIC_API_KEY=
PORT=3000
# Comma-separated allowed web origins for CORS. Leave unset in dev to reflect
# any origin (e.g. Expo web at http://localhost:8081). Set explicitly in prod.
CORS_ORIGINS=

# Brevo transactional email (password reset, etc). When BREVO_API_KEY is unset,
# emails are logged to the server instead of sent.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@riddhi.app
BREVO_SENDER_NAME=Riddhi
BREVO_SMS_SENDER=Riddhi
